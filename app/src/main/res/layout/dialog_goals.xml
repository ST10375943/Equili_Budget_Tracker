<?xml version="1.0" encoding="utf-8"?>
<!--
    Custom layout used inside the AlertDialog for setting monthly goals in DashboardActivity.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="20dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- Input for the minimum threshold -->
    <EditText
        android:id="@+id/etMinGoal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Minimum Monthly Spending Goal"
        android:inputType="numberDecimal"/>

    <!-- Input for the maximum limit -->
    <EditText
        android:id="@+id/etMaxGoal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="Maximum Monthly Spending Goal"
        android:inputType="numberDecimal"/>

</LinearLayout>
