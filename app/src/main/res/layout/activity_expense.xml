<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Global Visual Identity: Background and Theme Overlay -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/background"
        android:scaleType="centerCrop"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/appOverlayColor"/>

    <!-- ScrollView ensures content is accessible on smaller screens or in landscape -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Dynamic Header: Displays "New Expense" or "Edit Expense" -->
            <TextView
                android:id="@+id/tvHeader"
                android:text="New Expense"
                android:textSize="24sp"
                android:textColor="?attr/appTextColorPrimary"
                android:textStyle="bold"
                android:layout_gravity="center"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"/>

            <!-- INPUT: Monetary Value -->
            <EditText
                android:id="@+id/etAmount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Amount"
                android:inputType="numberDecimal"
                android:textColor="?attr/appTextColorPrimary"
                android:textColorHint="?attr/appTextColorSecondary"
                android:layout_marginTop="20dp"
                android:padding="12dp"
                android:background="@drawable/glass_card"/>

            <!-- INPUT: Title or Item description -->
            <EditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Description"
                android:textColor="?attr/appTextColorPrimary"
                android:textColorHint="?attr/appTextColorSecondary"
                android:layout_marginTop="16dp"
                android:padding="12dp"
                android:background="@drawable/glass_card"/>

            <!-- INPUT: Date and Duration Pickers -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:weightSum="3">

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Date"
                    android:textColor="?attr/appTextColorPrimary"
                    android:padding="12dp"
                    android:gravity="center"
                    android:background="@drawable/glass_card"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:id="@+id/tvStartTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Start"
                    android:textColor="?attr/appTextColorPrimary"
                    android:padding="12dp"
                    android:gravity="center"
                    android:background="@drawable/glass_card"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:id="@+id/tvEndTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="End"
                    android:textColor="?attr/appTextColorPrimary"
                    android:padding="12dp"
                    android:gravity="center"
                    android:background="@drawable/glass_card"/>
            </LinearLayout>

            <!-- SELECTION: Dropdown for custom categories -->
            <TextView
                android:text="Category"
                android:textColor="?attr/appTextColorSecondary"
                android:layout_marginTop="16dp"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"/>

            <Spinner
                android:id="@+id/spinnerCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/glass_card"
                android:padding="12dp"/>

            <!-- OPTIONAL: Receipt Attachment functionality -->
            <ImageView
                android:id="@+id/ivPreview"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="16dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:background="@drawable/glass_card"/>

            <Button
                android:id="@+id/btnCapture"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Capture Receipt (Optional)"
                android:layout_marginTop="8dp"
                android:backgroundTint="?attr/appCardBackground"
                android:textColor="?attr/appTextColorPrimary"/>

            <!-- FINAL ACTION: Persist data to Room -->
            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save Expense"
                android:backgroundTint="?attr/colorPrimary"
                android:textColor="@color/black"
                android:layout_marginTop="24dp"/>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
